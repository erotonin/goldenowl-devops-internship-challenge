aws_region   = "us-east-1"
project_name = "goldenowl"

vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.0.0/24",
  "10.0.1.0/24",
]

additional_tags = {
  Owner = "erotonin"
}

ecr_repository_name          = "goldenowl-app"
ecr_max_image_count          = 30
ecr_untagged_retention_days  = 7
enable_github_oidc           = false
github_repository            = "erotonin/goldenowl-devops-internship-challenge"
task_execution_role_arn      = "arn:aws:iam::ACCOUNT_ID:role/LabRole"
task_role_arn                = ""
approved_image_parameter     = "/goldenowl/staging/approved-image"
